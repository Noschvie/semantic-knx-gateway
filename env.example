# KNX Configuration
KNX_GATEWAY_IP=192.168.7.15
KNX_GATEWAY_PORT=3671
KNX_GATEWAY_PHYS_ADDR=1.1.200

# Semantic Layer Configuration (optional)
# Set this to a filename in the ./config/ directory to enable the semantic layer.
# The entire ./config directory is mounted to /app/config in the container.
# Example: KNX_TTL_FILE=MyProject.ttl
# If not set, the API will run without semantic enrichment and respond HTTP 503 for semantic endpoints.
KNX_TTL_FILE=project-prod.ttl

# API Configuration
API_PORT=3000

# --- Timezone ---
# Liste: https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
TZ=Europe/Vienna

# User-IDs für Docker
USER_ID=1000
GROUP_ID=1000

# Database Configuration
POSTGRES_HOST=timescaledb
POSTGRES_PORT=5432
POSTGRES_DB=knx
POSTGRES_USERNAME=knxuser
POSTGRES_PASSWORD=knxpassword

# Logging
LOG_LEVEL=info
NODE_ENV=development
PRETTY_LOGS=true

# ── OAuth2 Configuration ────────────────────────────────────────────────────
# Set to 'true' to disable Bearer token validation (dev/test only!)
OAUTH_DISABLED=true

# Lifetime of issued Access Tokens in seconds (default: 1440 = 24 min)
OAUTH_ACCESS_TTL=1440

# Lifetime of issued Refresh Tokens in seconds (default: 86400 = 24 h)
OAUTH_REFRESH_TTL=86400

# Secret for the built-in default client 'knx-default-client'
OAUTH_CLIENT_SECRET=change-me-in-production

# Additional OAuth clients as JSON map (optional)
# Format: {"clientId":{"secret":"...","allowedGrantTypes":["client_credentials"],"allowedScopes":["read","write","manage"]}}
OAUTH_CLIENTS={}

# Uncomment and set these on Raspberry Pi 4/5:
# TS_TUNE_MEMORY=2GB
# TS_TUNE_NUM_CPUS=4
