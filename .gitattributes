# .gitattributes — normalize end-of-line handling for the repository
# Recommended: keep source files with LF endings in the repo, allow Windows
# scripts to use CRLF where appropriate. This reduces "no newline at end of
# file" diffs and ensures consistent behavior across platforms and CI.

# Auto-detect text files and normalize them
* text=auto

# Force LF for common source files and documentation
*.js    text eol=lf
*.mjs   text eol=lf
*.cjs   text eol=lf
*.json  text eol=lf
*.md    text eol=lf
*.markdown text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf
*.html  text eol=lf
*.css   text eol=lf
*.ts    text eol=lf
*.tsx   text eol=lf
*.py    text eol=lf
*.sh    text eol=lf

# Keep Windows-specific scripts with CRLF (optional)
*.ps1   text eol=crlf
*.bat   text eol=crlf

# Treat common binary files as binary
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.ico   binary
*.zip   binary
*.gz    binary
*.jar   binary

# Ensure pack files (node modules, caches) are not normalized
node_modules/** -text

